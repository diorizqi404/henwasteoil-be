generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  COMMUNITY
  COLLECTOR
  STAKEHOLDER
}

enum CommunityCategory {
  HOUSEHOLD
  UMKM
  HOTEL_RESTAURANT
  INDUSTRY
}

enum SubmissionStatus {
  SUBMITTED
  ACCEPTED_BY_COLLECTOR
  REJECTED_BY_COLLECTOR
  IN_BATCH
  COMPLETED
}

enum BatchStatus {
  SUBMITTED_TO_STAKEHOLDER
  LAB_REVIEW
  ACCEPTED_BY_STAKEHOLDER
  REJECTED_BY_STAKEHOLDER
}

model User {
  id                String            @id @default(cuid())
  name              String
  email             String            @unique
  passwordHash      String
  role              Role
  phone             String?
  communityProfile  CommunityProfile?
  collectorProfile  CollectorProfile?
  stakeholderProfile StakeholderProfile?
  stakeholderSettings StakeholderSetting[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model CommunityProfile {
  id        String            @id @default(cuid())
  userId    String            @unique
  category  CommunityCategory
  address   String
  latitude  Float
  longitude Float
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissions CommunitySubmission[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model CollectorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  companyName     String
  address         String
  latitude        Float
  longitude       Float
  capacityLiter   Float
  buyPricePerLiter Float  @default(0)
  isActive        Boolean  @default(true)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissions     CommunitySubmission[]
  batches         CollectorBatch[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model StakeholderProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  companyName String
  address   String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StakeholderSetting {
  id                      String   @id @default(cuid())
  referencePricePerLiter  Float
  receptionLocationName   String
  receptionAddress        String
  latitude                Float
  longitude               Float
  updatedById             String
  updatedBy               User     @relation(fields: [updatedById], references: [id])
  batches                 CollectorBatch[]
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model CommunitySubmission {
  id                 String           @id @default(cuid())
  communityProfileId String
  collectorProfileId String
  estimatedLiter     Float
  scheduledDate      DateTime
  status             SubmissionStatus @default(SUBMITTED)
  actualLiter        Float?
  sedimentLiter      Float?
  cleanLiter         Float?
  pricePerLiter      Float?
  totalPaid          Float?
  collectorNote      String?
  communityProfile   CommunityProfile @relation(fields: [communityProfileId], references: [id])
  collectorProfile   CollectorProfile @relation(fields: [collectorProfileId], references: [id])
  batchItems          BatchItem[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model CollectorBatch {
  id                    String             @id @default(cuid())
  collectorProfileId    String
  stakeholderSettingId  String
  batchCode             String             @unique
  totalCleanLiter       Float
  requestedPricePerLiter Float
  estimatedTotalPrice   Float
  status                BatchStatus        @default(SUBMITTED_TO_STAKEHOLDER)
  finalLiter            Float?
  finalTotalPrice       Float?
  stakeholderNote       String?
  collectorProfile      CollectorProfile   @relation(fields: [collectorProfileId], references: [id])
  stakeholderSetting    StakeholderSetting @relation(fields: [stakeholderSettingId], references: [id])
  items                 BatchItem[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
}

model BatchItem {
  id                  String              @id @default(cuid())
  batchId             String
  submissionId        String
  cleanLiterAllocated Float
  batch               CollectorBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  submission          CommunitySubmission @relation(fields: [submissionId], references: [id])
  createdAt           DateTime            @default(now())

  @@unique([batchId, submissionId])
}
