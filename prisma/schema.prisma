generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  COMMUNITY
  COLLECTOR
  STAKEHOLDER
}

enum CommunityCategory {
  HOUSEHOLD
  UMKM
  HOTEL_RESTAURANT
  INDUSTRY
}

enum SubmissionStatus {
  SUBMITTED
  ACCEPTED_BY_COLLECTOR
  REJECTED_BY_COLLECTOR
  IN_BATCH
  COMPLETED
}

model User {
  id                String            @id @default(cuid())
  name              String
  email             String            @unique
  passwordHash      String
  role              Role
  phone             String?
  communityProfile  CommunityProfile?
  collectorProfile  CollectorProfile?
  stakeholderProfile StakeholderProfile?
  stakeholderSettings StakeholderSetting[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model CommunityProfile {
  id        String            @id @default(cuid())
  userId    String            @unique
  category  CommunityCategory
  address   String
  latitude  Float
  longitude Float
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissions CommunitySubmission[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model CollectorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  companyName     String
  address         String
  latitude        Float
  longitude       Float
  capacityLiter   Float
  buyPricePerLiter Float  @default(0)
  isActive        Boolean  @default(true)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissions     CommunitySubmission[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model StakeholderProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  companyName String
  address   String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StakeholderSetting {
  id                      String   @id @default(cuid())
  referencePricePerLiter  Float
  receptionLocationName   String
  receptionAddress        String
  latitude                Float
  longitude               Float
  updatedById             String
  updatedBy               User     @relation(fields: [updatedById], references: [id])
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model CommunitySubmission {
  id                 String           @id @default(cuid())
  communityProfileId String
  collectorProfileId String
  estimatedLiter     Float
  scheduledDate      DateTime
  status             SubmissionStatus @default(SUBMITTED)
  actualLiter        Float?
  sedimentLiter      Float?
  cleanLiter         Float?
  pricePerLiter      Float?
  totalPaid          Float?
  collectorNote      String?
  communityProfile   CommunityProfile @relation(fields: [communityProfileId], references: [id])
  collectorProfile   CollectorProfile @relation(fields: [collectorProfileId], references: [id])
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}
